{
  "name": "test-project",
  "version": "0.1.0",
  "notify": [],
  "daemon": {
    "schedule": {
      "radarCron": "0 */6 * * *",
      "writeCron": "*/15 * * * *"
    },
    "maxConcurrentBooks": 3
  },
  "language": "zh",
  "llm": {
    "services": [
      {
        "service": "codexForMeCodingPlan",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true
      },
      {
        "service": "localCodexMcp",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": false
      }
    ],
    "defaultModel": "local-codex",
    "service": "localCodexMcp",
    "provider": "openai",
    "baseUrl": "http://localhost/codex-mcp",
    "model": "local-codex",
    "cover": {
      "service": "localCodexImagegen",
      "model": "local-codex"
    },
    "temperature": 0.7,
    "apiFormat": "chat",
    "stream": false
  }
}